{
  "name": "centinela",
  "version": "1.0.0",
  "description": "Monitor de disponibilidad de servicios web hecho con Node.js",
  "main": "src/server.js",
  "bin": {
    "centinela": "bin/centinela.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "check": "node bin/centinela.js check",
    "stats": "node bin/centinela.js stats",
    "watch": "node bin/centinela.js watch",
    "backup": "node scripts/backup.js",
    "test": "node --test"
  },
  "keywords": [
    "monitoreo",
    "uptime",
    "devops",
    "nodejs",
    "cli"
  ],
  "author": "Jonas Suarez",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^4.5.0"
  }
}
